{
	"name": "pro-api-sdk",
	"version": "1.3.2",
	"description": "嘉立创EDA & EasyEDA 专业版扩展 API 开发工具",
	"author": "JLCEDA <support@lceda.cn>",
	"license": "Apache-2.0",
	"homepage": "https://pro.lceda.cn/",
	"engines": {
		"node": ">=20.17.0"
	},
	"scripts": {
		"test": "npm run test:geometry && npm run test:topology && npm run test:async-pool && npm run test:drc-repair && npm run test:snapshot-restore && npm run test:settings-inline && npm run test:shortcuts",
		"compile": "rimraf ./dist/ && ts-node ./config/esbuild.prod.ts",
		"lint": "eslint",
		"test:geometry": "ts-node ./scripts/test_arc_geometry.ts",
		"test:topology": "ts-node ./scripts/test_route_topology.ts",
		"test:async-pool": "ts-node ./scripts/test_async_pool.ts",
		"test:drc-repair": "ts-node --files ./scripts/test_drc_repair.ts",
		"test:snapshot-restore": "ts-node --files ./scripts/test_snapshot_restore.ts",
		"test:settings-inline": "ts-node ./scripts/test_settings_inline.ts",
		"test:shortcuts": "ts-node --files ./scripts/test_shortcuts.ts",
		"fix": "eslint --fix",
		"build": "npm run compile && ts-node ./build/packaged.ts"
	},
	"devDependencies": {
		"@antfu/eslint-config": "^5.4.1",
		"@jlceda/pro-api-types": "^0.3.4",
		"@types/fs-extra": "^11.0.4",
		"@types/jsdom": "^28.0.3",
		"esbuild": "^0.24.2",
		"eslint": "^9.37.0",
		"fs-extra": "^11.3.0",
		"ignore": "^7.0.3",
		"jsdom": "^29.1.1",
		"jszip": "^3.10.1",
		"lint-staged": "^16.2.3",
		"rimraf": "^6.0.1",
		"simple-git-hooks": "^2.13.1",
		"ts-node": "^10.9.2",
		"typescript": "^5.7.3"
	},
	"simple-git-hooks": {
		"pre-commit": "npx lint-staged"
	},
	"lint-staged": {
		"*": "eslint --fix"
	}
}
